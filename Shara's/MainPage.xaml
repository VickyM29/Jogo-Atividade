<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Shara_s.MainPage">

    <Grid BackgroundColor="#F0F9FF">
        <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="20">
            <Label Text="Bem-vindo ao Caça-Palavras!" 
               FontSize="24" 
               FontAttributes="Bold" 
               TextColor="#0284C7" 
               HorizontalOptions="Center" />
            <Button Text="Iniciar Jogo" 
                FontSize="18" 
                BackgroundColor="#0284C7" 
                TextColor="White" 
                Padding="10,5"
                Clicked="OnStartGameClicked" />
        </VerticalStackLayout>

</ContentPage>

    
