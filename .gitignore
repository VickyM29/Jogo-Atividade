# Diretórios de compilação
[Bb]in/
[Oo]bj/

# Arquivos de log e testes
*.log
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
*.trx
*.TestLogger.csv

# Diretório de cache e opções do Visual Studio
.vs/
*.user
*.userosscache
*.sln.docstates
*.suo

# Visual Studio Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# JetBrains Rider / ReSharper
.idea/
*.sln.iml
_ReSharper*/
*.[Rr]e[Ss]harper

# Arquivos de usuário do MonoDevelop / Xamarin Studio
*.userprefs

